# Plantilla del .env que consume docker-compose.yml.
# Copiar a `.env` en la raíz del repo y completar los valores marcados.
#   cp .env.example .env

# ── PostgreSQL (nueva) ────────────────────────────────────────────────────────
# POSTGRES_DB debe ser "promueva": el entrypoint del contenedor crea esta DB
# y los scripts de db/init/ y las migraciones asumen ese nombre.
POSTGRES_DB=promueva
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CAMBIAR_password_seguro

# ── PostgreSQL (legacy) ───────────────────────────────────────────────────────
POSTGRES_DB_LEGACY=promueva_legacy
POSTGRES_USER_LEGACY=postgres
POSTGRES_PASSWORD_LEGACY=CAMBIAR_password_seguro

# ── Conexión backend → DB (nombres de servicio dentro de la red de compose) ──
DB_HOST=postgres
DB_PORT=5432
DB_HOST_LEGACY=postgres
DB_PORT_LEGACY=5432

# ── Modos de aplicación ───────────────────────────────────────────────────────
APP_SKIP_DATABASE=false
APP_SERVER_MODE=true
APP_LOCAL_MODE=false
APP_LEGACY_DB=false
APP_SERVER_LOGS=false
APP_GENERAL_LOGS=true
APP_SIMULATION_LOGS=false
# Kill switch del streaming por websocket (true = la app funciona solo con
# el replay REST; útil como rollback si el WS da problemas en prod).
APP_SKIP_WS=false

# ── Firebase Auth ─────────────────────────────────────────────────────────────
# Ruta ABSOLUTA en la máquina host al JSON del service account de Firebase.
# docker-compose la monta como /secrets/firebase-sa.json dentro del contenedor.
# Sin este archivo, Firebase no inicializa y TODA autenticación (REST y
# websocket) falla.
FIREBASE_SA_HOST_PATH=/ruta/absoluta/al/firebase-sa.json

# ID del proyecto Firebase (Firebase Console → Project Settings)
FIREBASE_PROJECT_ID=usersopsim

# ── Bootstrap admin ───────────────────────────────────────────────────────────
# Emails separados por coma. Al hacer POST /api/users/sync, si el email del
# token está en esta lista se le asigna rol Administrator.
BOOTSTRAP_ADMIN_EMAILS=juan.sebastian.molina@correounivalle.edu.co

# ── JVM del backend (opcional) ────────────────────────────────────────────────
# Flags extra para la JVM del backend, p.ej. -Xmx8g según la RAM del server.
# Vacío = ergonomics por defecto del contenedor.
BACKEND_JAVA_OPTS=

# ── Front: URL del backend (OPCIONAL — normalmente NO definir) ────────────────
# Por defecto el front usa "/api" relativo al host de la página: funciona con
# IP pura o dominio, http o https, y el cambio IP→dominio NO requiere rebuild.
# Definir SOLO si el backend se expone en OTRO origen (p.ej. puerto directo
# sin proxy de path). Cambiarla requiere: docker compose build frontend.
#PUBLIC_BACKEND_URL=http://1.2.3.4:9000
